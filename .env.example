# Copy to .env and fill in. Never commit .env.
# Optional — only needed for LLM/agent features that call external APIs.

# OPENAI_API_KEY=
# GROQ_API_KEY=

# MLflow (override default sqlite backend if needed)
# MLFLOW_TRACKING_URI=sqlite:///./mlflow.db

# Gradio bind (when deploying the dashboard on a server)
# GRADIO_SERVER_NAME=127.0.0.1
# GRADIO_SERVER_PORT=7860
